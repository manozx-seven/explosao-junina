# Credenciais do Firebase Admin (conta de serviço).
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA faça commit do arquivo .env.

FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto-id.iam.gserviceaccount.com
# A chave deve ficar entre aspas e com os \n literais (uma linha só).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...cole...aqui...\n-----END PRIVATE KEY-----\n"
